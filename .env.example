# Copy this file to .env and fill in your keys
# Get FREE keys from each provider (no credit card needed):
#
#  GROQ       → https://console.groq.com           (fastest inference, llama3-70b free)
#  GEMINI     → https://aistudio.google.com/apikey  (Gemini 2.5 Flash, 1M tokens/day free)
#  OPENROUTER → https://openrouter.ai               (50+ free models, DeepSeek R1 free)
#  COHERE     → https://dashboard.cohere.com        (command-r-plus free trial)
#  MISTRAL    → https://console.mistral.ai          (mistral-small free tier)
#
# TIP: Add multiple keys per provider separated by commas.
# Ambrio auto-rotates to the next key when one hits rate limits.
# Example: GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3

GROQ_API_KEYS=
GEMINI_API_KEYS=
OPENROUTER_API_KEYS=
COHERE_API_KEYS=
MISTRAL_API_KEYS=
TOGETHER_API_KEYS=
CEREBRAS_API_KEYS=

# ── Optional: Override which model handles each task type ─────────────────────
# Uncomment and change to swap models without touching code:
#
# AMBRIO_MODEL_SIMPLE=ollama/llama3.2-1b        # fast local model for simple chats
# AMBRIO_MODEL_CHAT=groq/llama-3.3-70b          # main chat model
# AMBRIO_MODEL_COMPLEX=gemini/2.5-flash         # complex analysis and reports
# AMBRIO_MODEL_CODE=groq/deepseek-r1-70b        # code generation
# AMBRIO_MODEL_REASONING=openrouter/deepseek-r1 # math, logic, step-by-step
# AMBRIO_MODEL_VISION=gemini/2.5-flash          # image understanding
# AMBRIO_MODEL_FAST=groq/llama-3.1-8b           # ultra-fast responses

# ── Ollama local server (default is localhost) ────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
