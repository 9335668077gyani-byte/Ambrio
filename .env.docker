# .env.docker
# Copy to .env and fill in real API keys before running Docker Compose
# This file is safe to commit (no real secrets — only variable names)

# ─── LLM API Keys ─────────────────────────────────────────────────────────────
GROQ_API_KEYS=
GEMINI_API_KEYS=
OPENROUTER_API_KEYS=
COHERE_API_KEYS=
MISTRAL_API_KEYS=
TOGETHER_API_KEYS=
CEREBRAS_API_KEYS=

# ─── ChromaDB (HTTP mode) ─────────────────────────────────────────────────────
CHROMA_MODE=http
CHROMA_HOST=chromadb
CHROMA_PORT=8000
# Production only — leave empty for dev:
CHROMA_AUTH_TOKEN=

# ─── Ollama ───────────────────────────────────────────────────────────────────
# In Docker: service name resolves via Docker DNS
OLLAMA_BASE_URL=http://ollama:11434

# ─── App paths (Docker volumes) ───────────────────────────────────────────────
AMBRIO_DB_PATH=/data/db/ambrio.db
AMBRIO_CHROMA_DIR=/data/chroma

# ─── Runtime ──────────────────────────────────────────────────────────────────
AMBRIO_ENV=development
LOG_LEVEL=info
UVICORN_WORKERS=2

# ─── Model overrides (optional) ───────────────────────────────────────────────
# AMBRIO_MODEL_REASONING=groq/llama-3.3-70b
# AMBRIO_MODEL_CHAT=groq/llama-3.3-70b
# AMBRIO_MODEL_VISION=gemini/2.5-flash
# AMBRIO_MODEL_FAST=groq/llama-3.1-8b
